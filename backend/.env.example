APP_NAME=Workflow Orchestrator API
APP_ENV=development
APP_DEBUG=true
APP_LOG_LEVEL=INFO
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
CORS_ORIGIN_REGEX=^https?://(localhost|127\.0\.0\.1|10\.\d+\.\d+\.\d+|172\.(1[6-9]|2\d|3[0-1])\.\d+\.\d+|192\.168\.\d+\.\d+)(:\d+)?$
UPLOAD_DIR=uploads
UPLOAD_MAX_MB=20
DATABASE_URL=postgresql+psycopg2://workflow:workflow@db:5432/workflow
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=openai/gpt-4o-mini
OPENROUTER_TIMEOUT_S=30
OPENROUTER_REFERER=http://localhost
OPENROUTER_APP_NAME=ai-workflow-orchestrator
OPENROUTER_MOCK=false
AUTH_SECRET_KEY=
AUTH_ALGORITHM=HS256
AUTH_ACCESS_TOKEN_EXP_MINUTES=1440

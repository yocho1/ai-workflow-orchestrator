# Shared defaults
APP_NAME=Workflow Orchestrator API
APP_ENV=development
APP_DEBUG=true
APP_LOG_LEVEL=INFO

# PostgreSQL
POSTGRES_DB=workflow
POSTGRES_USER=workflow
POSTGRES_PASSWORD=workflow
POSTGRES_PORT=5432

# Backend
BACKEND_PORT=8000
DATABASE_URL=postgresql+psycopg2://workflow:workflow@db:5432/workflow
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=openai/gpt-4o-mini
OPENROUTER_TIMEOUT_S=30
OPENROUTER_REFERER=http://localhost
OPENROUTER_APP_NAME=ai-workflow-orchestrator
OPENROUTER_MOCK=false

# Frontend
FRONTEND_PORT=5173
VITE_API_BASE_URL=http://localhost:8000/api/v1
